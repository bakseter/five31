{
    "name": "five31",
    "version": "0.1.0",
    "private": true,
    "enginesStrict": true,
    "engines": {
        "node": "24.x"
    },
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint .",
        "format": "prettier -w \"**/*.{ts,tsx,js,jsx,mjs,css,json,md}\"",
        "pcheck": "prettier -c \"**/*.{ts,tsx,js,jsx,mjs,css,json,md}\"",
        "test": "vitest run"
    },
    "prettier": {
        "semi": true,
        "trailingComma": "all",
        "singleQuote": true,
        "printWidth": 120,
        "tabWidth": 4,
        "overrides": [
            {
                "files": "*.json",
                "options": {
                    "trailingComma": "none"
                }
            }
        ]
    },
    "dependencies": {
        "@tailwindcss/postcss": "4.3.1",
        "date-fns": "4.4.0",
        "next": "16.2.9",
        "next-auth": "5.0.0-beta.31",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "typescript-json-decoder": "1.0.11"
    },
    "devDependencies": {
        "@babel/core": "7.29.7",
        "@eslint/compat": "2.1.0",
        "@eslint/eslintrc": "3.3.5",
        "@eslint/js": "10.0.1",
        "@testing-library/react": "16.3.2",
        "@types/node": "25.9.3",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@typescript-eslint/parser": "8.59.1",
        "@vitejs/plugin-react": "6.0.2",
        "autoprefixer": "10.5.0",
        "cypress": "15.17.0",
        "eslint": "10.5.0",
        "eslint-config-next": "16.2.9",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-prettier": "5.5.6",
        "eslint-plugin-simple-import-sort": "13.0.0",
        "eslint-plugin-unicorn": "65.0.1",
        "globals": "17.6.0",
        "jsdom": "29.1.1",
        "postcss": "8.5.15",
        "prettier": "3.8.4",
        "tailwindcss": "4.3.1",
        "typescript": "6.0.3",
        "typescript-eslint": "8.59.1",
        "vite": "8.0.16",
        "vitest": "4.1.8",
        "webpack": "5.107.2"
    }
}
