{
    "name": "five31",
    "version": "0.1.0",
    "private": true,
    "enginesStrict": true,
    "engines": {
        "node": "24.x"
    },
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint .",
        "format": "prettier -w \"**/*.{ts,tsx,js,jsx,mjs,css,json,md}\"",
        "pcheck": "prettier -c \"**/*.{ts,tsx,js,jsx,mjs,css,json,md}\"",
        "test": "vitest run"
    },
    "prettier": {
        "semi": true,
        "trailingComma": "all",
        "singleQuote": true,
        "printWidth": 120,
        "tabWidth": 4,
        "overrides": [
            {
                "files": "*.json",
                "options": {
                    "trailingComma": "none"
                }
            }
        ]
    },
    "dependencies": {
        "@tailwindcss/postcss": "4.2.2",
        "date-fns": "4.1.0",
        "next": "16.2.4",
        "next-auth": "5.0.0-beta.31",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "typescript-json-decoder": "1.0.11"
    },
    "devDependencies": {
        "@babel/core": "7.29.0",
        "@eslint/compat": "2.0.5",
        "@eslint/eslintrc": "3.3.5",
        "@eslint/js": "10.0.1",
        "@testing-library/react": "16.3.2",
        "@types/node": "25.6.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@typescript-eslint/parser": "8.58.2",
        "@vitejs/plugin-react": "6.0.1",
        "autoprefixer": "10.5.0",
        "cypress": "15.14.0",
        "eslint": "10.2.1",
        "eslint-config-next": "16.2.4",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-prettier": "5.5.5",
        "eslint-plugin-simple-import-sort": "13.0.0",
        "eslint-plugin-unicorn": "64.0.0",
        "globals": "17.5.0",
        "jsdom": "29.0.2",
        "postcss": "8.5.10",
        "prettier": "3.8.3",
        "tailwindcss": "4.2.2",
        "typescript": "6.0.3",
        "typescript-eslint": "8.58.2",
        "vite": "8.0.9",
        "vitest": "4.1.4",
        "webpack": "5.106.2"
    },
    "pnpm": {
        "overrides": {
            "@types/react": "19.2.14",
            "@types/react-dom": "19.2.3"
        }
    }
}
